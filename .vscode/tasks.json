                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Echo server build",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "-Wall",
                "${workspaceFolder}/webproxy-lab/echoserver/echoserver.c",
                "${workspaceFolder}/webproxy-lab/echoserver/echo.c",
                "${workspaceFolder}/webproxy-lab/csapp.c",
                "-o",
                "${workspaceFolder}/webproxy-lab/echoserver/echoserver",
                "-lpthread"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "options": {
                "cwd": "${workspaceFolder}/webproxy-lab/echoserver"
            }
        },
        {
            "label": "Echo server clean",
            "type": "shell",
            "command": "rm",
            "args": [
                "-f",
                "${workspaceFolder}/webproxy-lab/echoserver/echoserver"
